# Telegram Bot Configuration
# Obtain your token by messaging @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# NVIDIA Developer API Configuration
# Obtain your API key by signing up at https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# NVIDIA Image Generation API endpoint
# Standard OpenAI-compatible serverless endpoint:
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/images/generations

# Model identifier (e.g. black-forest-labs/flux-1-schnell or stabilityai/stable-diffusion-3-5-large)
NVIDIA_MODEL=black-forest-labs/flux-1-schnell

# Number of inference steps (lower = faster generation, e.g. 2 for flux-1-schnell)
NVIDIA_STEPS=2
